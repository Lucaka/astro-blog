---
import { getRelativeLocaleUrl } from "astro:i18n";
import { LOCALES, LOCALE_META, type Locale } from "../i18n/config";
import { useTranslations } from "../i18n";

/**
 * Locale switcher: one link per locale for the *current* page. `path` is the
 * locale-agnostic page path (e.g. "" for the index, "posts/foo/" for a post);
 * `getRelativeLocaleUrl` turns it into the right prefixed URL per locale
 * (prefix-less for the default `zh-hant`, `/en/…` for the rest).
 */
interface Props {
	locale: Locale;
	path?: string;
}
const { locale, path = "" } = Astro.props;
const t = useTranslations(locale);
---

<nav class="lang-switch" aria-label={t("nav.language")}>
	{
		LOCALES.map((l) => (
			<a
				href={getRelativeLocaleUrl(l, path)}
				hreflang={LOCALE_META[l].htmlLang}
				lang={LOCALE_META[l].htmlLang}
				aria-current={l === locale ? "true" : undefined}
				class:list={["lang-switch__item", { "is-active": l === locale }]}
			>
				{LOCALE_META[l].short}
			</a>
		))
	}
</nav>

<style>
	.lang-switch {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		font-size: 13px;
	}
	.lang-switch__item {
		display: inline-block;
		min-width: 26px;
		padding: 3px 8px;
		border-radius: 8px;
		text-align: center;
		color: #8ab4ff;
		text-decoration: none;
		opacity: 0.7;
		transition:
			background-color 0.15s ease,
			opacity 0.15s ease;
	}
	.lang-switch__item:hover,
	.lang-switch__item:focus-visible {
		background: rgba(255, 255, 255, 0.08);
		opacity: 1;
	}
	.lang-switch__item.is-active {
		color: #eef2ff;
		opacity: 1;
		font-weight: 600;
		pointer-events: none;
	}
</style>
