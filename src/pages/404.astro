---
import { getCollection } from "astro:content";
import { postPath } from "../utils/posts";

/**
 * Themed 404: GitHub Pages serves the built `404.html` for any unknown URL
 * under the site, so a mistyped or moved post link lands here instead of the
 * default GitHub error page. Lists every post so lost readers have somewhere
 * to go.
 */
const entries = (await getCollection("posts")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<html lang="zh-Hant">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>404 — James Universe</title>
		<meta name="robots" content="noindex" />
		<meta name="theme-color" content="#05070f" />
	</head>
	<body>
		<main class="lost">
			<p class="lost__code" aria-hidden="true">404</p>
			<h1 class="lost__title">這顆星星不在這片宇宙裡</h1>
			<p class="lost__text">
				可能是連結打錯了，或這篇文章已經飄向了別的星系。
			</p>
			<a class="lost__home" href={`${base}/`}>← 返回宇宙</a>

			<section class="lost__posts">
				<h2>或者，看看這些星星</h2>
				<ul>
					{entries.map((entry) => (
						<li>
							<a href={postPath(entry.id)}>{entry.data.title}</a>
							<span class="lost__date">{entry.data.date}</span>
						</li>
					))}
				</ul>
			</section>
		</main>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
	}
	html,
	body {
		margin: 0;
		padding: 0;
		background: radial-gradient(ellipse at 50% -10%, #131a30 0%, #05070f 60%, #000 100%);
		min-height: 100vh;
		color: #eef2ff;
		font-family:
			ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	}

	.lost {
		max-width: 640px;
		margin: 0 auto;
		padding: clamp(48px, 12vh, 120px) clamp(20px, 5vw, 32px) 64px;
	}
	.lost__code {
		margin: 0;
		font-size: clamp(64px, 14vw, 110px);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0.06em;
		background: linear-gradient(180deg, #8ab4ff 0%, #3a4a7a 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	.lost__title {
		margin: 18px 0 8px;
		font-size: clamp(22px, 4.5vw, 30px);
		line-height: 1.3;
	}
	.lost__text {
		margin: 0 0 20px;
		font-size: 15px;
		line-height: 1.7;
		opacity: 0.75;
	}
	.lost__home {
		color: #8ab4ff;
		text-decoration: none;
		font-size: 15px;
	}
	.lost__home:hover,
	.lost__home:focus-visible {
		text-decoration: underline;
	}

	.lost__posts {
		margin-top: 48px;
	}
	.lost__posts h2 {
		font-size: 15px;
		font-weight: 600;
		letter-spacing: 0.08em;
		opacity: 0.6;
	}
	.lost__posts ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.lost__posts li {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
		padding: 9px 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.lost__posts a {
		color: #eef2ff;
		text-decoration: none;
	}
	.lost__posts a:hover,
	.lost__posts a:focus-visible {
		color: #8ab4ff;
		text-decoration: underline;
	}
	.lost__date {
		flex: none;
		font-size: 12px;
		opacity: 0.5;
	}
</style>
