---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { byDateDesc } from "../../../utils/posts";
import { tagSlug } from "../../../utils/tags";
import TagPage from "../../../components/pages/TagPage.astro";

type PostEntry = CollectionEntry<"posts">;

/**
 * English per-tag page. Shares <TagPage> with the zh-hant route; the listed
 * post titles aren't translated, but the chrome is. Same grouping as the
 * zh-hant route so both locales expose the identical tag set.
 */
export async function getStaticPaths() {
	const entries = (await getCollection("posts")).sort(byDateDesc);

	const groups = new Map<string, { tag: string; posts: PostEntry[] }>();
	for (const entry of entries) {
		for (const tag of entry.data.tags) {
			const slug = tagSlug(tag);
			let group = groups.get(slug);
			if (!group) {
				group = { tag, posts: [] };
				groups.set(slug, group);
			}
			group.posts.push(entry);
		}
	}

	return [...groups].map(([slug, { tag, posts }]) => ({
		params: { tag: slug },
		props: { tag, posts },
	}));
}

const { tag, posts } = Astro.props as { tag: string; posts: PostEntry[] };
---

<TagPage locale="en" tag={tag} posts={posts} />
