---
import { getCollection, render } from "astro:content";
import BlackHole from "../components/BlackHole.vue";
import type { Post } from "../data/posts";
import { byDateDesc, parseDisplayDate, readingTimeMinutes, postPath } from "../utils/posts";

// Load every star from the Markdown content collection, newest first.
const entries = (await getCollection("posts")).sort(byDateDesc);

// Metadata handed to the 3D island (stars + hover tooltip + search).
const posts: Post[] = entries.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  date: entry.data.date,
  category: entry.data.category,
  tags: entry.data.tags,
  summary: entry.data.summary,
  minutes: readingTimeMinutes(entry.body ?? ""),
}));

// Server-render each Markdown body once; the reading panel reads the matching
// node's HTML by slug when a star is opened.
const bodies = await Promise.all(
  entries.map(async (entry) => ({
    slug: entry.id,
    Content: (await render(entry)).Content,
  })),
);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const description =
  "James Universe — 在 3D 宇宙裡探索的部落格:前端、圖學與隨筆。每顆星星都是一篇文章。";
const ogImage = new URL(`${base}/og.png`, Astro.site);

// Structured data: tell search engines this is a blog and list every post.
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "James Universe",
  url: new URL(`${base}/`, Astro.site),
  description,
  inLanguage: "zh-Hant",
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    description: post.summary,
    datePublished: parseDisplayDate(post.date).toISOString().slice(0, 10),
    url: new URL(postPath(post.slug), Astro.site),
  })),
  // JSON.stringify leaves "</" intact, so a title/summary containing
  // "</script>" could break out of the inline script tag; escape "<".
}).replace(/</g, "\\u003c");
---

<html lang="zh-Hant">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>James Universe</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={new URL(`${base}/`, Astro.site)} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="James Universe"
			href={`${base}/rss.xml`}
		/>
		<meta name="theme-color" content="#05070f" />
		<link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="James Universe" />
		<meta property="og:locale" content="zh_TW" />
		<meta property="og:title" content="James Universe" />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={new URL(`${base}/`, Astro.site)} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="James Universe — 3D 宇宙部落格的黑洞星空" />
		<meta name="twitter:card" content="summary_large_image" />
		<script is:inline type="application/ld+json" set:html={jsonLd} />
	</head>
	<body>
		{/* Real links to every post: keyboard/screen-reader users can Tab through
		    them (visible on focus), search engines can crawl them, and with JS
		    off the <noscript> style below turns this into the whole page. */}
		<nav class="post-index" aria-label="所有文章">
			<h1 class="post-index__title">James Universe</h1>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={postPath(post.slug)}>
							<strong>{post.title}</strong>
							<span class="post-index__meta">{post.date} · {post.summary}</span>
						</a>
					</li>
				))}
			</ul>
		</nav>

		{/* First paint: a static splash so the first load isn't a black screen
		    while the 3D bundle downloads. The island fades it out once the
		    scene is actually rendering. */}
		<div id="universe-loading" class="universe-loading" aria-hidden="true">
			<p class="universe-loading__title">James Universe</p>
			<p class="universe-loading__sub">正在點亮星空…</p>
		</div>

		<noscript>
			<style>
				/* Without JS the universe can't render: promote the link list to a
				   normal, visible page instead of a black screen. Hide the JS-only
				   loading splash so it never sits on top of the list. */
				#universe-loading {
					display: none !important;
				}
				.post-index {
					position: fixed !important;
					inset: 0 !important;
					overflow: auto !important;
					pointer-events: auto !important;
					padding: 48px clamp(20px, 6vw, 64px) !important;
				}
				.post-index__title,
				.post-index a {
					position: static !important;
					width: auto !important;
					height: auto !important;
					clip-path: none !important;
				}
				.post-index li {
					margin: 14px 0 !important;
				}
			</style>
		</noscript>

		<BlackHole client:only="vue" posts={posts} />

		{/* Hidden, server-rendered Markdown bodies, pulled into the panel by slug. */}
		<div class="post-bodies" aria-hidden="true">
			{bodies.map(({ slug, Content }) => (
				<article id={`post-body-${slug}`}><Content /></article>
			))}
		</div>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		padding: 0;
		background: #000;
		overflow: hidden;
	}

	.post-bodies {
		display: none;
	}

	/* Static loading splash: contentful first paint before any JS arrives.
	   Sits above the (initially empty) canvas layer; the island adds
	   `--done` after the first rendered frame, then removes the node. */
	.universe-loading {
		position: fixed;
		inset: 0;
		z-index: 10;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		background: radial-gradient(ellipse at 50% 42%, #10172b 0%, #05070f 55%, #000 100%);
		color: #eef2ff;
		font-family:
			ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
		transition: opacity 0.7s ease;
		pointer-events: none;
	}
	.universe-loading--done {
		opacity: 0;
	}
	.universe-loading__title {
		margin: 0;
		font-size: clamp(22px, 4vw, 32px);
		font-weight: 700;
		letter-spacing: 0.14em;
	}
	.universe-loading__sub {
		margin: 0;
		font-size: 13px;
		letter-spacing: 0.22em;
		color: #8ea0cc;
		animation: universe-loading-pulse 2.2s ease-in-out infinite;
	}
	@keyframes universe-loading-pulse {
		0%,
		100% {
			opacity: 0.35;
		}
		50% {
			opacity: 0.9;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.universe-loading {
			transition-duration: 0.01s;
		}
		.universe-loading__sub {
			animation: none;
			opacity: 0.7;
		}
	}

	/* Visually hidden but focusable: each link pops into view when Tabbed to.
	   The container itself must NOT be clipped — a clip-path on the ancestor
	   would also clip the revealed, fixed-position focused link. */
	.post-index {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 40;
		pointer-events: none;
		color: #eef2ff;
		font-family:
			ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	}
	.post-index ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-index__title {
		position: fixed;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip-path: inset(50%);
		margin: 0;
		font-size: 24px; /* only visible in the promoted noscript layout */
	}
	.post-index a {
		position: fixed;
		top: 12px;
		left: 12px;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip-path: inset(50%);
		color: #eef2ff;
		text-decoration: none;
		pointer-events: auto;
	}
	.post-index a:focus {
		width: auto;
		height: auto;
		clip-path: none;
		z-index: 41;
		display: block;
		max-width: min(480px, 90vw);
		padding: 12px 16px;
		border-radius: 12px;
		background: rgba(12, 16, 28, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.2);
		outline: 2px solid #8ab4ff;
	}
	.post-index__meta {
		display: block;
		font-size: 13px;
		opacity: 0.7;
		margin-top: 4px;
	}
</style>
